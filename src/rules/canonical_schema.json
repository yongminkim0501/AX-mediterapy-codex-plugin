{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meditherapy Seeding Plan",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "objective": { "type": "string" }
      }
    },
    "market": { "$ref": "#/$defs/confidentString" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gender": { "$ref": "#/$defs/confidentString" },
        "age_group": { "$ref": "#/$defs/confidentString" }
      }
    },
    "kpis": {
      "type": "array",
      "items": { "$ref": "#/$defs/confidentString" }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tracking_link": { "$ref": "#/$defs/confidentBoolean" },
        "coupon_code": { "$ref": "#/$defs/confidentBoolean" },
        "purchase_event": { "$ref": "#/$defs/confidentBoolean" }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limit": { "$ref": "#/$defs/confidentNumber" },
        "currency": { "$ref": "#/$defs/confidentString" }
      }
    },
    "planned_cost": { "$ref": "#/$defs/confidentNumber" },
    "is_experiment_plan": { "$ref": "#/$defs/confidentBoolean" },
    "experiment_hypothesis": { "$ref": "#/$defs/confidentString" }
  },
  "$defs": {
    "confidentString": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["value", "confidence"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "raw_value": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      ]
    },
    "confidentBoolean": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "required": ["value", "confidence"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "boolean" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "raw_value": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      ]
    },
    "confidentNumber": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "required": ["value", "confidence"],
          "additionalProperties": false,
          "properties": {
            "value": { "type": "number" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "raw_value": { "type": ["string", "number", "boolean", "null"] }
          }
        }
      ]
    }
  }
}
